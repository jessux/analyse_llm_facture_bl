# URL de base de l'API Azure OpenAI (APIM)
APIM_OPENAI_BASE_URL=https://your-apim.azure-api.net/openai/v1

# Clé API Azure APIM
APIM_OPENAI_API_KEY=your-api-key-here

# Chemin vers le fichier XLSM de trésorerie (optionnel, défaut: output/Suivi trésorerie MLC.xlsm)
TRESORERIE_XLSM_PATH=output/Suivi trésorerie MLC.xlsm

# Chemin vers la base de données SQLite (optionnel, défaut: output/data.db)
MARJO_DB_PATH=output/data.db

# Dossier de stockage des PDFs importés (optionnel, défaut: storage)
MARJO_STORAGE_DIR=storage

# Origines CORS autorisées, séparées par des virgules (optionnel, défaut: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000
